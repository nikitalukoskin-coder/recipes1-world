{
  "version": 2,
  "routes": [
    {
      "src": "/_/backend(.*)",
      "dest": "/backend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "builds": [
    {
      "src": "frontend/**/*",
      "use": "@vercel/next"
    },
    {
      "src": "backend/**/*",
      "use": "@vercel/node"
    }
  ]
}
